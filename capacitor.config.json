{
  "appId": "mg.cinox.app",
  "appName": "CinoX",
  "webDir": "public",
  "server": {
    "url": "https://YOUR_REPLIT_APP_URL.replit.app",
    "cleartext": false,
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#6C3CE1",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#6C3CE1"
    },
    "Keyboard": {
      "resize": "body",
      "style": "dark"
    }
  }
}
